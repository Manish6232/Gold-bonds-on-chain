# Get from https://alchemy.com - create a Polygon Mumbai app
ALCHEMY_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Your MetaMask wallet private key (export from MetaMask > Account Details)
# NEVER commit this to GitHub
PRIVATE_KEY=your_metamask_private_key_here

# Get from https://polygonscan.com/apis (for contract verification, optional)
POLYGONSCAN_KEY=your_polygonscan_api_key
