# Alchemy RPC URL for Polygon Mumbai
ALCHEMY_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Admin wallet private key (MetaMask > Account Details > Export Private Key)
# This wallet pays gas for all user transactions (gasless relay)
PRIVATE_KEY=your_admin_wallet_private_key_here

# Contract addresses — filled automatically by deploy.js
BOND_CONTRACT_ADDRESS=0x...
MARKETPLACE_CONTRACT_ADDRESS=0x...

# Get free key from https://nft.storage
NFT_STORAGE_KEY=your_nft_storage_key

# Server port
PORT=3001
